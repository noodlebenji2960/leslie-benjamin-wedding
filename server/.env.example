# Server Configuration
PORT=3001
NODE_ENV=development

# CORS / URLs
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001

# Image Upload
MAX_FILE_SIZE=10485760

# AWS S3
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=leslie-benjamin-wedding-photos
# Optional CloudFront CDN (if set, image URLs use this base instead of S3)
# CLOUDFRONT_URL=https://d3xyz123abc.cloudfront.net

# MongoDB
MONGODB_URI=mongodb://localhost:27017/wedding-gallery

# Admin UI
ADMIN_PASSWORD=changeme
SESSION_SECRET=change-me-in-production

# Admin password reset (forgot-password OTP email)
RESEND_API_KEY=
ADMIN_RESET_EMAIL=
EMAIL_FROM=noreply@leslie-and-benjamin.es
